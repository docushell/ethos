{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ethos:schema:deterministic-profile:1",
  "title": "Ethos deterministic profile manifest",
  "description": "The checker schema for profiles/ethos-deterministic-*.json. The profile pins everything that may influence canonical output: c14n version, quantization, font policy, backend build identity, warning policy, config-hash inputs, and the runtime fields excluded from canonical equality. The profile artifact's own sha256 (over its c14n bytes) enters every document fingerprint.",
  "type": "object",
  "required": [
    "profile_id",
    "profile_version",
    "schema_version",
    "c14n",
    "quantization",
    "id_scheme",
    "font_policy",
    "backend",
    "warning_policy",
    "config_hash_inputs",
    "canonical_exclusions"
  ],
  "additionalProperties": false,
  "properties": {
    "profile_id": { "type": "string", "pattern": "^ethos-deterministic-v[0-9]+$" },
    "profile_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "c14n": {
      "type": "object",
      "required": ["version", "spec"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^c14n-v[0-9]+$" },
        "spec": { "const": "docs/determinism-contract.md" }
      }
    },
    "quantization": {
      "type": "object",
      "required": ["quantum_per_point", "rounding", "stage"],
      "additionalProperties": false,
      "properties": {
        "quantum_per_point": { "type": "integer", "minimum": 1 },
        "rounding": { "const": "half-away-from-zero" },
        "stage": {
          "const": "extraction",
          "description": "Invariant 1: quantization happens in ethos-pdf at extraction, before any heuristic consumes coordinates. Enforced by type (QuantizedGeom)."
        }
      }
    },
    "id_scheme": {
      "type": "object",
      "required": ["version"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "description": "ID derivation scheme version (determinism contract §5): ids are functions of canonical traversal order." }
      }
    },
    "font_policy": {
      "type": "object",
      "required": ["adr", "substitution_table", "fallback_bundle", "system_font_fallback"],
      "additionalProperties": false,
      "properties": {
        "adr": { "const": "ADR-0003" },
        "substitution_table": {
          "type": "object",
          "required": ["path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$", "description": "null until WS-ENGINE lands the table (Milestone A week 2)." }
          }
        },
        "fallback_bundle": {
          "type": "object",
          "required": ["name", "license", "sha256"],
          "additionalProperties": false,
          "properties": {
            "name": { "const": "liberation" },
            "license": { "const": "OFL-1.1" },
            "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
          }
        },
        "system_font_fallback": { "const": "disabled" }
      }
    },
    "backend": {
      "type": "object",
      "description": "PDFium build identity (ADR-0002). The Release 1 deterministic profile pins Phase 1 bblanchon artifacts; Public Beta requires phase=2.",
      "required": [
        "id",
        "phase",
        "version",
        "upstream_version",
        "v8",
        "xfa",
        "distribution",
        "build_flags",
        "platform_hashes",
        "platform_artifacts",
        "profile_doc"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "const": "pdfium" },
        "phase": { "enum": [1, 2] },
        "version": { "type": "string", "minLength": 1 },
        "upstream_version": { "type": "string", "minLength": 1 },
        "v8": { "const": "disabled" },
        "xfa": { "const": "disabled" },
        "distribution": {
          "type": "object",
          "required": ["source", "release_url", "published_at", "attestation"],
          "additionalProperties": false,
          "properties": {
            "source": { "const": "bblanchon/pdfium-binaries" },
            "release_url": {
              "type": "string",
              "pattern": "^https://github\\.com/bblanchon/pdfium-binaries/releases/tag/.+"
            },
            "published_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
            "attestation": {
              "type": "object",
              "required": ["name", "sha256"],
              "additionalProperties": false,
              "properties": {
                "name": { "const": "pdfium-attestation.json" },
                "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
              }
            }
          }
        },
        "build_flags": {
          "type": "object",
          "required": [
            "is_component_build",
            "is_debug",
            "pdf_enable_v8",
            "pdf_enable_xfa",
            "pdf_is_standalone",
            "pdf_use_partition_alloc"
          ],
          "additionalProperties": false,
          "properties": {
            "is_component_build": { "const": false },
            "is_debug": { "const": false },
            "pdf_enable_v8": { "const": false },
            "pdf_enable_xfa": { "const": false },
            "pdf_is_standalone": { "const": true },
            "pdf_use_partition_alloc": { "const": false }
          }
        },
        "platform_hashes": {
          "type": "object",
          "minProperties": 3,
          "additionalProperties": false,
          "patternProperties": {
            "^(macos-arm64|macos-x64|linux-x64|linux-arm64|windows-x64)$": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        },
        "platform_artifacts": {
          "type": "object",
          "minProperties": 3,
          "additionalProperties": false,
          "patternProperties": {
            "^(macos-arm64|macos-x64|linux-x64|linux-arm64|windows-x64)$": {
              "type": "object",
              "required": [
                "name",
                "target_os",
                "target_cpu",
                "runtime_library_path",
                "runtime_library_sha256"
              ],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "pattern": "^pdfium-[a-z0-9-]+\\.tgz$" },
                "target_os": { "enum": ["mac", "linux", "win"] },
                "target_cpu": { "enum": ["arm64", "x64"] },
                "runtime_library_path": { "type": "string", "minLength": 1 },
                "runtime_library_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                }
              }
            }
          }
        },
        "profile_doc": { "const": "docs/pdfium-profile.md" }
      }
    },
    "warning_policy": {
      "type": "object",
      "required": ["messages", "ordering"],
      "additionalProperties": false,
      "properties": {
        "messages": { "const": "fixed-templates" },
        "ordering": { "const": "canonical-traversal" }
      }
    },
    "config_hash_inputs": {
      "type": "array",
      "description": "Exactly which effective-config fields enter config_sha256 (determinism contract §7).",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "canonical_exclusions": {
      "type": "array",
      "description": "Runtime fields that exist in artifacts but sit OUTSIDE canonical equality.",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
