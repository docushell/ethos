{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ethos:benchmarks:gate-zero-result:1",
  "title": "Ethos Gate Zero result",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "corpus",
    "parser_target",
    "command",
    "exit_code",
    "duration_ms_p50",
    "duration_ms_p95",
    "duration_ms_p99",
    "peak_rss_bytes",
    "output_sha256",
    "install_size_bytes",
    "host",
    "deterministic_profile_sha256",
    "inputs",
    "readiness",
    "blockers",
    "competitors",
    "runs",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "ethos-gate-zero-result-v1" },
    "status": { "enum": ["blocked", "pass", "fail"] },
    "corpus": {
      "type": "object",
      "required": ["id", "manifest", "manifest_sha256"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "manifest": { "type": "string" },
        "manifest_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "parser_target": { "type": "string" },
    "command": { "type": "array", "items": { "type": "string" } },
    "exit_code": { "type": ["integer", "null"] },
    "duration_ms_p50": { "type": ["number", "null"], "minimum": 0 },
    "duration_ms_p95": { "type": ["number", "null"], "minimum": 0 },
    "duration_ms_p99": { "type": ["number", "null"], "minimum": 0 },
    "peak_rss_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "output_sha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "install_size_bytes": { "type": "integer", "minimum": 0 },
    "host": { "type": "object" },
    "deterministic_profile_sha256": {
      "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "inputs": { "type": "object" },
    "readiness": { "type": "object" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "competitors": { "type": "object" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "corpus_file",
          "parser_target",
          "command",
          "exit_code",
          "duration_ms_p50",
          "duration_ms_p95",
          "duration_ms_p99",
          "peak_rss_bytes",
          "output_sha256",
          "document_fingerprint",
          "warning_ids",
          "status",
          "failures"
        ],
        "additionalProperties": false,
        "properties": {
          "corpus_file": { "type": "object" },
          "parser_target": { "type": "string" },
          "command": { "type": "array", "items": { "type": "string" } },
          "exit_code": { "type": ["integer", "null"] },
          "duration_ms_p50": { "type": ["number", "null"], "minimum": 0 },
          "duration_ms_p95": { "type": ["number", "null"], "minimum": 0 },
          "duration_ms_p99": { "type": ["number", "null"], "minimum": 0 },
          "peak_rss_bytes": { "type": ["integer", "null"], "minimum": 0 },
          "output_sha256": {
            "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
          },
          "document_fingerprint": { "type": ["string", "null"] },
          "warning_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "enum": ["pass", "fail"] },
          "failures": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "summary": { "type": "object" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
